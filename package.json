{
  "name": "cardio-remoto-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "npm run -w @cardio/mobile start",
    "ios": "npm run -w @cardio/mobile ios",
    "android": "npm run -w @cardio/mobile android",
    "backend": "npm run -w @cardio/backend dev",
    "backend:start": "npm run -w @cardio/backend start",
    "test": "npm run -w @cardio/shared test && npm run -w @cardio/backend test && npm run -w @cardio/mobile test",
    "test:unit": "npm run -w @cardio/shared test",
    "test:mobile": "npm run -w @cardio/mobile test",
    "test:e2e": "bash e2e/run-e2e.sh",
    "test:e2e:granular": "bash e2e/run-e2e.sh e2e/tests",
    "typecheck": "npm run -w @cardio/shared typecheck && npm run -w @cardio/mobile typecheck",
    "lint": "npm run -w @cardio/mobile lint"
  },
  "engines": {
    "node": ">=20"
  }
}
